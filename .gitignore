# Virtual environment — recreatable, no need to track
.venv/

# Python cache files — auto-generated, not source code
__pycache__/
*.pyc
*.pyo

# Package build artifacts
*.egg-info/
dist/
build/

# Jupyter auto-save files
.ipynb_checkpoints/

# Output rasters — too large for Git, use Google Drive or DVC instead
outputs/

# Earth Engine credentials — NEVER commit these
.config/earthengine/

# Secrets file — NEVER commit this
.env

# macOS folder metadata
.DS_Store

# Append to .gitignore
@"
# Data — too large for Git
data/raw/
data/interim/
data/processed/

# Keep folder structure
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# Reports (optional — keep figures out of Git)
reports/figures/
!reports/notes.md
"@ | Out-File -FilePath .gitignore -Append -Encoding UTF8